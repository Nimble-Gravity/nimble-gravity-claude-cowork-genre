{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Dev Server",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/dev_server.py",
      "args": ["--port", "8000"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "Serving .+ at (http://[^\\s]+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    }
  ]
}
